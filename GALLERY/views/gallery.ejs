<!DOCTYPE html>
<html>

<head>
    <title>TWO SHADES OF NATURE</title>

    <style>
        * {
            box-sizing: border-box;
        }
        
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background: #0f172a;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .header {
            margin-top: 40px;
            padding: 12px 30px;
            font-size: 2.4rem;
            font-weight: 700;
            color: #facc15;
            border: 2px solid #facc15;
            border-radius: 14px;
            letter-spacing: 2px;
            background: rgba(250, 204, 21, 0.08);
        }
        
        .gallery {
            margin-top: 50px;
            padding: 20px;
            display: flex;
            gap: 50px;
            flex-wrap: wrap;
            justify-content: center;
        }
        
        .photo-card {
            padding: 16px;
            border-radius: 18px;
            background: #020617;
            border: 2px solid rgba(250, 204, 21, 0.4);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }
        
        .photo-card:hover {
            transform: translateY(-6px) scale(1.03);
            box-shadow: 0 18px 40px rgba(250, 204, 21, 0.25);
        }
        
        .photo-card img {
            display: block;
            width: 260px;
            height: 320px;
            object-fit: cover;
            border-radius: 12px;
            border: 3px solid #facc15;
            padding: 4px;
            background: #020617;
        }
        /* Pagination */
        
        .pagination {
            margin: 40px 0;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            justify-content: center;
        }
        
        .pagination a {
            padding: 8px 14px;
            border: 2px solid #facc15;
            border-radius: 8px;
            text-decoration: none;
            color: #facc15;
            transition: 0.2s ease;
        }
        
        .pagination a:hover {
            background: #facc15;
            color: #020617;
        }
        
        .active-page {
            background: #facc15;
            color: #020617 !important;
        }
        /* small screens */
        
        @media (max-width: 600px) {
            .photo-card img {
                width: 200px;
                height: 260px;
            }
            .header {
                font-size: 1.6rem;
                text-align: center;
            }
        }
    </style>
</head>

<body>

    <div class="header">
        IMAGES
    </div>

    <div class="gallery">
        <% images.forEach(img => { %>
            <div class="photo-card">
                <img src="<%= img %>" alt="Image">
            </div>
            <% }) %>
    </div>

    <!-- Pagination -->
    <div class="pagination">

        <% if (currentPage > 1) { %>
            <a href="/?page=<%= currentPage - 1 %>">Previous</a>
            <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="/?page=<%= i %>" class="<%= i === currentPage ? 'active-page' : '' %>">
                        <%= i %>
                    </a>
                    <% } %>

                        <% if (currentPage < totalPages) { %>
                            <a href="/?page=<%= currentPage + 1 %>">Next</a>
                            <% } %>

    </div>

</body>

</html>